{
  "schema": "hidloom.public-export-deny-patterns.v1",
  "block": [
    {
      "id": "private_key",
      "pattern": "-----BEGIN (?:(?:OPENSSH|RSA|EC|DSA|ENCRYPTED) )?PRIVATE KEY-----"
    },
    {
      "id": "github_token",
      "pattern": "(?:ghp|github_pat)_[A-Za-z0-9_]{20,}"
    },
    {
      "id": "aws_access_key",
      "pattern": "AKIA[0-9A-Z]{16}"
    },
    {
      "id": "personal_home_path",
      "pattern": "/home/(?!pi(?:/|\\b)|user(?:/|\\b)|example(?:/|\\b)|USERNAME(?:/|\\b)|\\.\\.\\./)[A-Za-z0-9._-]+/"
    },
    {
      "id": "windows_personal_home",
      "pattern": "[A-Za-z]:\\\\Users\\\\(?!Public\\\\|USERNAME\\\\)[^\\\\\r\n]+\\\\"
    },
    {
      "id": "private_machine_hostname",
      "pattern": "(?i)(?<![A-Za-z0-9])(?:codex[0-9]{3}|li[0-9]{2})(?![A-Za-z0-9])"
    },
    {
      "id": "private_personal_username",
      "pattern": "(?i)(?<![A-Za-z0-9])fuji[k]awa(?![A-Za-z0-9])"
    },
    {
      "id": "retired_software_owner_namespace",
      "pattern": "(?i)c[q]a02303(?!v5|/)",
      "exclude_path_globs": [
        "config/publication-policy.json",
        "kicad/**"
      ]
    },
    {
      "id": "retired_dbus_namespace",
      "pattern": "(?i)/(?:com|org)/c[q]a02303(?:/|$)"
    },
    {
      "id": "private_documentation_path",
      "pattern": "(?i)^docs/(?:.*(?:-handoff|-next-start|-(?:progress|status|audit)-20\\d{2}-\\d{2}-\\d{2})\\.md|ops/(?:workflow-runbook|repository-layout-inventory)\\.md)$"
    }
  ],
  "warn": [
    {
      "id": "private_ipv4",
      "pattern": "\\b(?:10(?:\\.\\d{1,3}){3}|192\\.168(?:\\.\\d{1,3}){2}|172\\.(?:1[6-9]|2\\d|3[01])(?:\\.\\d{1,3}){2})\\b"
    },
    {
      "id": "credential_word",
      "pattern": "(?i)\\b(?:password|passwd|secret|token|ssid|psk)\\b"
    },
    {
      "id": "legacy_project_name",
      "pattern": "(?i)c[q]a02303v5rpi|c[q]a[-_]"
    },
    {
      "id": "linux_foundation_vid",
      "pattern": "(?i)0x1d6b"
    }
  ]
}
