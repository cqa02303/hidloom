#!/bin/sh
case "$1" in
 start) HIDLOOM_M1_PRODUCT="CQA02303v5 M3 Matrix Keyboard" /usr/bin/hidloom-hid-gadget-m1 start ;;
 stop) /usr/bin/hidloom-hid-gadget-m1 stop ;;
 restart) /usr/bin/hidloom-hid-gadget-m1 stop; HIDLOOM_M1_PRODUCT="CQA02303v5 M3 Matrix Keyboard" /usr/bin/hidloom-hid-gadget-m1 start ;;
 *) exit 1 ;;
esac
